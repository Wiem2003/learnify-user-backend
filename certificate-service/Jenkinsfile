// Jenkinsfile — Certificate Service
// Pipeline CI pour le microservice Certificate
pipeline {
    agent any
    
    tools {
        maven 'M2_HOME'
        jdk ' JAVA_HOME'
    }
    
    environment {
        // ── Variables spécifiques au Certificate Service ──
        IMAGE_NAME = 'taher1239/certificate-service'
        IMAGE_TAG = 'latest'
        BUILD_TAG = "${BUILD_NUMBER}"
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_CREDS_ID = 'docker-hub-credentials'
    }
    
    stages {
        stage('1 — Checkout') {
            steps {
                echo '📥 Checking out Certificate Service code...'
                
                script {
                    // Configure Git for large repositories
                    sh '''
                        git config --global http.postBuffer 524288000
                        git config --global http.lowSpeedLimit 0
                        git config --global http.lowSpeedTime 999999
                    '''
                    
                    // Checkout from certificate branch
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: '*/certificate']],
                        extensions: [
                            [$class: 'CloneOption', 
                             depth: 1, 
                             noTags: true, 
                             shallow: true, 
                             timeout: 120]
                        ],
                        userRemoteConfigs: [[
                            credentialsId: 'github-credentials',
                            url: 'https://github.com/Wiem2003/learnify-user-backend.git'
                        ]]
                    ])
                    
                    env.GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                }
                
                echo "✅ Code récupéré depuis GitHub — branche certificate"
                echo "✅ Commit: ${env.GIT_COMMIT_SHORT}"
            }
        }
        
        stage('2 — Build Maven') {
            steps {
                echo '🔨 Building Certificate Service with Maven...'
                dir('certificate-service') {
                    sh 'mvn clean compile -DskipTests'
                    echo "✅ Build Maven terminé : certificate-service"
                }
            }
        }
        
        stage('3 — Tests') {
            steps {
                echo '🧪 Running tests for Certificate Service...'
                dir('certificate-service') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    // Publier les résultats de tests dans Jenkins
                    junit 'certificate-service/target/surefire-reports/*.xml'
                }
                failure {
                    error 'Tests échoués — arrêt du pipeline'
                }
            }
        }
        
        stage('4 — Package') {
            steps {
                echo '📦 Packaging Certificate Service...'
                dir('certificate-service') {
                    sh 'mvn package -DskipTests'
                    echo "✅ Package créé : certificate-service/target/*.jar"
                }
            }
        }
        
        stage('5 — Build Docker Image') {
            steps {
                echo '🐳 Building Docker image for Certificate Service...'
                dir('certificate-service') {
                    script {
                        // Build avec 2 tags : latest et numéro de build
                        sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                        sh "docker build -t ${IMAGE_NAME}:${BUILD_TAG} ."
                        echo "✅ Image Docker construite : ${IMAGE_NAME}:${IMAGE_TAG}"
                        echo "✅ Image Docker construite : ${IMAGE_NAME}:${BUILD_TAG}"
                    }
                }
            }
        }
        
        stage('6 — Push to Docker Hub') {
            steps {
                echo '📤 Pushing Certificate Service image to Docker Hub...'
                script {
                    docker.withRegistry("https://${DOCKER_REGISTRY}", "${DOCKER_CREDS_ID}") {
                        sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                        sh "docker push ${IMAGE_NAME}:${BUILD_TAG}"
                        echo "✅ Image publiée sur Docker Hub : ${IMAGE_NAME}:${IMAGE_TAG}"
                        echo "✅ Image publiée sur Docker Hub : ${IMAGE_NAME}:${BUILD_TAG}"
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ Pipeline CI réussi — Certificate Service"
            echo "✅ Images disponibles sur Docker Hub :"
            echo "   - ${IMAGE_NAME}:${IMAGE_TAG}"
            echo "   - ${IMAGE_NAME}:${BUILD_TAG}"
        }
        failure {
            echo "❌ Pipeline CI échoué — vérifier les logs ci-dessus"
        }
        always {
            // Nettoyer pour libérer l'espace disque Jenkins
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            sh "docker rmi ${IMAGE_NAME}:${BUILD_TAG} || true"
        }
    }
}
