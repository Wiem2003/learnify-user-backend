pipeline {
    agent any
    environment {
        IMAGE_NAME = "rahmouta/frontend-service"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }
    stages {

        stage('Checkout') {
            steps {
                git branch: 'frontend-service-rahma',
                    url: 'https://github.com/Wiem2003/learnify-user-backend.git'
            }
        }

        stage('Verify Frontend') {
            steps {
                sh '''
                    echo "=== Workspace root ==="
                    ls -la frontend

                    echo "=== Checking required config files ==="
                    test -f frontend/tsconfig.json     || { echo "MISSING: tsconfig.json";     exit 1; }
                    test -f frontend/tsconfig.app.json || { echo "MISSING: tsconfig.app.json"; exit 1; }
                    test -f frontend/angular.json      || { echo "MISSING: angular.json";      exit 1; }

                    echo "All required config files present."
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    cd frontend && docker build \
                        --label "build=${BUILD_NUMBER}" \
                        -t $IMAGE_NAME:$IMAGE_TAG .
                '''
            }
        }

        stage('Docker Login & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'Docker-ID',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh '''
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push $IMAGE_NAME:$IMAGE_TAG
                        docker tag  $IMAGE_NAME:$IMAGE_TAG $IMAGE_NAME:latest
                        docker push $IMAGE_NAME:latest
                        docker logout
                    '''
                }
            }
        }
    }

    post {
        always {
            sh 'docker system prune -af || true'
        }
    }
}
