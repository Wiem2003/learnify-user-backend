{
  "info": {
    "name": "YallaTn API",
    "description": "Complete API collection for YallaTn Job Application Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.collectionVariables.set('sessionId', pm.response.json().sessionId);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@learnify.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login - Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.collectionVariables.set('sessionId', pm.response.json().sessionId);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@learnify.com\",\n  \"password\": \"teacher123\"\n}"
            }
          }
        },
        {
          "name": "Login - Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.collectionVariables.set('sessionId', pm.response.json().sessionId);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@learnify.com\",\n  \"password\": \"student123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/auth/current-user"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "{{sessionId}}"}
            ],
            "url": "{{baseUrl}}/api/jobs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Software Engineering Professor\",\n  \"nbPlaces\": 2,\n  \"description\": \"Teaching advanced software engineering\",\n  \"requirements\": \"PhD in Computer Science, 5+ years experience\",\n  \"deadline\": \"2026-03-30T23:59:59\"\n}"
            }
          }
        },
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/jobs"
          }
        },
        {
          "name": "Get Open Jobs",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/jobs/open"
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/jobs/1"
          }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "{{sessionId}}"}
            ],
            "url": "{{baseUrl}}/api/jobs/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Senior Software Engineering Professor\",\n  \"nbPlaces\": 3,\n  \"description\": \"Updated description\",\n  \"requirements\": \"Updated requirements\",\n  \"deadline\": \"2026-04-15T23:59:59\",\n  \"status\": \"OPEN\"\n}"
            }
          }
        },
        {
          "name": "Close Job",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/jobs/1/close"
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/jobs/1"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application (with files)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "{{sessionId}}"}],
            "url": "{{baseUrl}}/api/applications",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "application", "value": "{\"jobId\": 1, \"motivation\": \"I am highly qualified\"}", "type": "text"},
                {"key": "cv", "type": "file", "src": ""},
                {"key": "certificat", "type": "file", "src": ""}
              ]
            }
          }
        },
