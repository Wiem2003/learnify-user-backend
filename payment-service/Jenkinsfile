pipeline {
    agent any
    
    tools {
        maven 'M2_HOME'
        jdk ' JAVA_HOME'
    }
    
    environment {
        IMAGE_NAME = 'taher1239/payment-service'
        IMAGE_TAG = 'latest'
        BUILD_TAG = "${BUILD_NUMBER}"
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_CREDS_ID = 'docker-hub-credentials'
    }
    
    stages {
        stage('1 — Checkout') {
            steps {
                echo '📥 Checking out Payment Service code...'
                script {
                    sh '''
                        git config --global http.postBuffer 524288000
                        git config --global http.lowSpeedLimit 0
                        git config --global http.lowSpeedTime 999999
                    '''
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: '*/payment']],
                        extensions: [
                            [$class: 'CloneOption', 
                             depth: 1, 
                             noTags: true, 
                             shallow: true, 
                             timeout: 120]
                        ],
                        userRemoteConfigs: [[
                            credentialsId: 'github-credentials',
                            url: 'https://github.com/Wiem2003/learnify-user-backend.git'
                        ]]
                    ])
                    env.GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                }
                echo "✅ Code récupéré — branche payment — commit: ${env.GIT_COMMIT_SHORT}"
            }
        }
        
        stage('2 — Build Maven') {
            steps {
                echo '🔨 Building Payment Service...'
                dir('payment-service') {
                    sh 'mvn clean compile -DskipTests'
                }
                echo "✅ Build Maven terminé"
            }
        }
        
        stage('3 — Tests') {
            steps {
                echo '🧪 Running tests...'
                dir('payment-service') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'payment-service/target/surefire-reports/*.xml'
                }
            }
        }

        stage('4 — SonarQube Analysis') {
    steps {
        echo '🔍 Running SonarQube analysis...'
        dir('payment-service') {
            withSonarQubeEnv('SonarQube') {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh 'mvn sonar:sonar -Dsonar.projectKey=payment-service -Dsonar.projectName="Payment Service" -Dsonar.token=$SONAR_TOKEN -Dsonar.host.url=http://192.168.106.80:9000'
                }
            }
        }
        echo "✅ SonarQube analysis terminée"
    }
}
        
        stage('5 — Package') {
            steps {
                echo '📦 Packaging...'
                dir('payment-service') {
                    sh 'mvn package -DskipTests'
                }
                echo "✅ Package créé"
            }
        }
        
        stage('6 — Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                dir('payment-service') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_TAG} ."
                }
                echo "✅ Image Docker construite : ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
        
        stage('7 — Push to Docker Hub') {
            steps {
                echo '📤 Pushing to Docker Hub...'
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDS_ID}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:${BUILD_TAG}
                    '''
                }
                echo "✅ Pushed: ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }
    
    post {
        success {
            echo "✅ Pipeline Payment Service SUCCESS"
        }
        failure {
            echo "❌ Pipeline Payment Service FAILED"
        }
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            sh "docker rmi ${IMAGE_NAME}:${BUILD_TAG} || true"
        }
    }
}
