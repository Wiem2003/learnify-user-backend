// Jenkinsfile — API Gateway
// Pipeline CI pour le microservice API Gateway
pipeline {
    agent any
    
    tools {
        maven 'M2_HOME'
        jdk ' JAVA_HOME'
    }
    
    environment {
        // ── Variables spécifiques au API Gateway ──
        IMAGE_NAME = 'taher1239/api-gateway'
        IMAGE_TAG = 'latest'
        BUILD_TAG = "${BUILD_NUMBER}"
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_CREDS_ID = 'docker-hub-credentials'
    }
    
    stages {
        stage('1 — Checkout') {
            steps {
                echo '📥 Checking out API Gateway code...'
                
                script {
                    // Configure Git for large repositories
                    sh '''
                        git config --global http.postBuffer 524288000
                        git config --global http.lowSpeedLimit 0
                        git config --global http.lowSpeedTime 999999
                    '''
                    
                    // Checkout from api-gateway branch
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: '*/api-gateway']],
                        extensions: [
                            [$class: 'CloneOption', 
                             depth: 1, 
                             noTags: true, 
                             shallow: true, 
                             timeout: 120]
                        ],
                        userRemoteConfigs: [[
                            credentialsId: 'github-credentials',
                            url: 'https://github.com/Wiem2003/learnify-user-backend.git'
                        ]]
                    ])
                    
                    env.GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                }
                
                echo "✅ Code récupéré depuis GitHub — branche api-gateway"
                echo "✅ Commit: ${env.GIT_COMMIT_SHORT}"
            }
        }
        
        stage('2 — Build Maven') {
            steps {
                echo '🔨 Building API Gateway with Maven...'
                dir('api-gateway') {
                    sh 'mvn clean compile -DskipTests'
                    echo "✅ Build Maven terminé : api-gateway"
                }
            }
        }
        
        stage('3 — Tests') {
            steps {
                echo '🧪 Running tests for API Gateway...'
                dir('api-gateway') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    // Publier les résultats de tests dans Jenkins (si des tests existent)
                    junit allowEmptyResults: true, testResults: 'api-gateway/target/surefire-reports/*.xml'
                }
            }
        }
        
        stage('4 — Package') {
            steps {
                echo '📦 Packaging API Gateway...'
                dir('api-gateway') {
                    sh 'mvn package -DskipTests'
                    echo "✅ Package créé : api-gateway/target/*.jar"
                }
            }
        }
        
        stage('5 — Build Docker Image') {
            steps {
                echo '🐳 Building Docker image for API Gateway...'
                dir('api-gateway') {
                    script {
                        // Build avec 2 tags : latest et numéro de build
                        sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                        sh "docker build -t ${IMAGE_NAME}:${BUILD_TAG} ."
                        echo "✅ Image Docker construite : ${IMAGE_NAME}:${IMAGE_TAG}"
                        echo "✅ Image Docker construite : ${IMAGE_NAME}:${BUILD_TAG}"
                    }
                }
            }
        }
        
        stage('6 — Push to Docker Hub') {
            steps {
                echo '📤 Pushing API Gateway image to Docker Hub...'
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh '''
                            echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                            docker push ${IMAGE_NAME}:${IMAGE_TAG}
                            docker push ${IMAGE_NAME}:${BUILD_TAG}
                        '''
                        echo "✅ Image publiée sur Docker Hub : ${IMAGE_NAME}:${IMAGE_TAG}"
                        echo "✅ Image publiée sur Docker Hub : ${IMAGE_NAME}:${BUILD_TAG}"
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ Pipeline CI réussi — API Gateway"
            echo "✅ Images disponibles sur Docker Hub :"
            echo "   - ${IMAGE_NAME}:${IMAGE_TAG}"
            echo "   - ${IMAGE_NAME}:${BUILD_TAG}"
        }
        failure {
            echo "❌ Pipeline CI échoué — vérifier les logs ci-dessus"
        }
        always {
            // Nettoyer pour libérer l'espace disque Jenkins
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            sh "docker rmi ${IMAGE_NAME}:${BUILD_TAG} || true"
        }
    }
}
